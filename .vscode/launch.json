{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch example/default (sqlite)",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/example/default",
      "cwd": "${workspaceFolder}/example/default",
      "linux": {
        "program": "${workspaceFolder}/example/default",
        "cwd": "${workspaceFolder}/example/default",
        "dlvToolPath": "/root/go/bin/dlv",
        "env": {
          "CGO_ENABLED": "0"
        }
      },
      "buildFlags": "-tags=sqlite",
      "env": {
        "CGO_ENABLED": "0"
      },
      "args": [
        "-c",
        "config.yaml"
      ]
    }
  ]
}
